generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String     @id @default(cuid())
  slackId           String     @unique
  email             String     @unique
  slackToken        String?
  gmailToken        String?
  calendarToken     String?
  youtubeToken      String?
  githubToken       String?
  twilioToken       String?
  toneStyle         String     @default("professional")
  autoReplyEmail    Boolean    @default(true)
  autoReplySlack    Boolean    @default(false)
  attendMeetings    Boolean    @default(true)
  answerCalls       Boolean    @default(true)
  meetingsAttended  Int        @default(0)
  emailsReplied     Int        @default(0)
  slackReplied      Int        @default(0)
  youtubeSummarized Int        @default(0)
  callsAnswered     Int        @default(0)
  hoursSaved        Float      @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  briefings         Briefing[]
  meetings          Meeting[]
}

model Briefing {
  id        String   @id @default(cuid())
  userId    String
  content   String
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Meeting {
  id         String   @id @default(cuid())
  userId     String
  meetingUrl String
  title      String
  startTime  DateTime
  endTime    DateTime
  attended   Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id])
}
